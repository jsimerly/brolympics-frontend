# E2E lane (vite --mode e2e): everything local, everything fake. The demo-
# project id + fake API key guarantee a hard failure if the auth-emulator
# wiring ever breaks -- tests can never fall through to real Firebase.
VITE_API_URL=http://127.0.0.1:8001
VITE_FRONTEND_URL=http://127.0.0.1:5175
VITE_FB_API_KEY=fake-e2e-api-key
VITE_FB_AUTH_DOMAIN=127.0.0.1
VITE_PROJECT_ID=demo-brolympics
VITE_STORAGE_BUCKET=demo-brolympics.appspot.com
VITE_MESSAGING_SENDER_ID=0
VITE_APP_ID=demo-e2e
VITE_MEASUREMENT_ID=
VITE_FB_AUTH_EMULATOR=127.0.0.1:9099
